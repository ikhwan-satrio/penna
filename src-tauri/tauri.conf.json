{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "penna",
  "version": "1.0.0",
  "identifier": "com.ikhwan-satrio.penna",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "decorations": false,
        "title": "penna",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "backgroundColor": "#080812"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "rpm": {
        "compression": {
          "type": "gzip",
          "level": 6
        }
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
